{
  "name": "double-check",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A second pair of eyes for the numbers that can't be wrong.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:privacy": "bash scripts/check-privacy.sh",
    "zip": "cd dist && zip -r ../double-check.zip . -x '.*'"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0",
    "extpay": "^3.1.1",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.0.270",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
